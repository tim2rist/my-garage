# ─────────────────────────────────────────────────────────────
#  MyGarage – Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000

# Frontend origin (used for CORS)
CLIENT_ORIGIN=http://localhost:5173

# JWT secret – change this to a random string in production!
JWT_SECRET=mygarage_super_secret_change_me_2026

# ── AWS S3 (image uploads) ────────────────────────────────────
# Leave blank to run without S3 (images will be stored as base64 URLs)

AWS_REGION=eu-central-1
AWS_BUCKET_NAME=my-mygarage-bucket
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
